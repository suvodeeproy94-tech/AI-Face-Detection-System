# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Python build and package output
build/
dist/
*.egg-info/
.eggs/
*.egg

# Python virtual environments
.venv/
venv/
env/
ENV/

# Python tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local environment files
.env
.env.*
!.env.example
.envrc

# Flask and SQLite generated files
instance/
backend/data/*.db
backend/data/*.sqlite
backend/data/*.sqlite3
db.sqlite3
db.sqlite3-journal

# Frontend dependencies and build output
frontend/node_modules/
frontend/dist/

# Large datasets should not be committed
datasets/WIDER_FACE/images/*
datasets/WIDER_FACE/annotations/*
datasets/FDDB/images/*
datasets/FDDB/annotations/*
!datasets/WIDER_FACE/images/.gitkeep
!datasets/WIDER_FACE/annotations/.gitkeep
!datasets/FDDB/images/.gitkeep
!datasets/FDDB/annotations/.gitkeep

# Large model binaries should be added only when intentionally needed
backend/models/face_detector_model/*
!backend/models/face_detector_model/.gitkeep
!backend/models/face_detector_model/face_detection_yunet_2023mar.onnx

# Editor and operating system files
.vscode/
.idea/
.DS_Store
Thumbs.db
tempCodeRunnerFile.py
